# TEMPLETON_SECRET: Fernet key for state token encryption/authentication.
# Leave blank to auto-generate a fresh key on each `templeton up`.
# Supply a fixed value for reproducible test matrix runs.
TEMPLETON_SECRET=

# TEMPLETON_TIER: Which tier to run.
#   1 = Playtest (fixed trap assignments, deterministic)
#   2 = War Game (procedural, adversarial — Phase 10+)
TEMPLETON_TIER=1

# TEMPLETON_RUN_ID: Set automatically by `templeton up`. Do not set manually.
TEMPLETON_RUN_ID=
